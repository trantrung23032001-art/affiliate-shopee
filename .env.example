# Mã affiliate ID của bạn trên Shopee
# Đăng nhập Shopee Affiliate -> Lấy mã ở link redirect
# Mặc định: 17337630000
AFFILIATE_ID=17337630000

# Link bài viết Facebook để user comment link affiliate
# (Nhằm áp dụng mã giảm giá)
FACEBOOK_POST_URL=https://www.facebook.com

# Link nhóm Zalo thông báo lên mã giảm giá
