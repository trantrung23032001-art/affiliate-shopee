# Link Zalo hỗ trợ / trợ giúp
ZALO_HELP_URL=https://zalo.me

# Sub ID để tracking (tuỳ chọn)
# Dùng để phân loại nguồn traffic
# Mặc định: ----- (5 dấu gạch ngang)
SUB_ID=-----